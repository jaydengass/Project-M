# TMDB API Key - Get one from https://www.themoviedb.org/settings/api
VITE_TMDB_READ_API_KEY=...

# Enable/disable OpenSearch functionality
VITE_OPENSEARCH_ENABLED=false

# CORS proxy URL - make sure the cors proxy url does NOT have a slash at the end
# Set this to handle CORS issues with external APIs
# Example: https://cors-proxy.example.com
VITE_CORS_PROXY_URL=...

# Application domain - make sure the domain does NOT have a slash at the end
# For GitHub Pages: https://yourusername.github.io/repository-name
# For local development: http://localhost:5173
VITE_APP_DOMAIN=http://localhost:5173

# Base URL for the application
# For GitHub Pages: /repository-name/
# For root domain: /
VITE_BASE_URL=/

# Router mode - use hash routing for GitHub Pages
# Set to "true" for proper routing, "false" for hash-based routing
VITE_NORMAL_ROUTER=false

# PWA Configuration
# Set to "true" to enable Progressive Web App functionality
VITE_PWA_ENABLED=false

# Enable development features
VITE_DEVELOPMENT=false
